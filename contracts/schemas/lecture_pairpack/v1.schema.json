{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/lecture_pairpack.v1.schema.json",
  "title": "Lecture PairPack",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "document", "pages"],
  "properties": {
    "schema": {
      "const": "lecture_pairpack.v1"
    },
    "document": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "page_count"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "source_pdf_url": { "type": "string" },
        "page_count": { "type": "integer", "minimum": 0 },
        "prompt_version": { "type": "string" },
        "model": { "type": "string" }
      }
    },
    "pages": {
      "type": "array",
      "items": { "$ref": "#/$defs/page" }
    }
  },
  "$defs": {
    "page": {
      "type": "object",
      "additionalProperties": false,
      "required": ["page_no", "source", "teaching", "status"],
      "properties": {
        "page_no": {
          "type": "integer",
          "minimum": 1
        },
        "source": {
          "type": "object",
          "additionalProperties": false,
          "required": ["pdf_page_ref", "text_md", "ocr_used", "parser"],
          "properties": {
            "pdf_page_ref": { "type": "string" },
            "text_md": { "type": "string" },
            "ocr_used": { "type": "boolean" },
            "parser": { "type": "string" },
            "page_type": {
              "type": "string",
              "enum": ["title", "agenda", "concept", "example", "figure", "table", "formula", "exercise", "summary", "blank", "unknown"]
            }
          }
        },
        "teaching": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "slide_title",
            "speaker_notes_md",
            "concepts",
            "visual_explanations",
            "formula_explanations",
            "evidence",
            "confidence",
            "needs_review",
            "needs_parser_fallback"
          ],
          "properties": {
            "slide_title": { "type": "string" },
            "speaker_notes_md": { "type": "string" },
            "concepts": {
              "type": "array",
              "items": { "type": "string" }
            },
            "prerequisites": {
              "type": "array",
              "items": { "type": "string" }
            },
            "contextual_bridge": {
              "type": "string"
            },
            "visual_explanations": {
              "type": "array",
              "items": { "type": "string" }
            },
            "formula_explanations": {
              "type": "array",
              "items": { "type": "string" }
            },
            "evidence": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["kind", "quote_or_reference"],
                "properties": {
                  "kind": {
                    "type": "string",
                    "enum": ["title", "keyword", "formula", "figure", "table", "caption", "layout", "other"]
                  },
                  "quote_or_reference": { "type": "string" }
                }
              }
            },
            "confidence": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "needs_review": { "type": "boolean" },
            "needs_parser_fallback": { "type": "boolean" }
          }
        },
        "status": {
          "type": "string",
          "enum": ["queued", "running", "ready", "needs_review", "failed"]
        }
      }
    }
  }
}

